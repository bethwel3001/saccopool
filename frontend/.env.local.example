# --- SaccoChain frontend environment ---
# Soroban testnet RPC
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Deployed SaccoPool contract id (see CONTRACT_ADDRESSES.md)
NEXT_PUBLIC_POOL_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Testnet USDC SAC contract id
NEXT_PUBLIC_USDC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# Reserve index of USDC inside the pool (usually 0 for SaccoChain)
NEXT_PUBLIC_USDC_RESERVE_INDEX=0

# Display only
NEXT_PUBLIC_TARGET_APR=10

# When "true", the dashboard runs deposit/borrow/repay/withdraw against an
# in-browser simulator that mirrors the on-chain SaccoPool logic (including
# the 2× borrow cap). The deployed SaccoPool contract and its
# `get_member_stats` view are still callable on-chain. Flip to "false" once
# the USDC reserve has been queued + activated on the live pool.
NEXT_PUBLIC_SIMULATOR_MODE=false
